{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "maoloader",
  "version": "0.1.3",
  "identifier": "com.steel.maoloader",
  "build": {
    "beforeDevCommand": "bun run dev:tauri",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:tauri",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "maoloader",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZEMzYyRTg5OTkyRTNCMEUKUldRT095NlppUzQyYmJiNkFXWmFxSmxRZWdHQmo1VW1rSU5Oejg3RkhNMCs2ZnVKb0ZMWlVPUS8K",
      "endpoints": [
        "https://maoloader.com/api/releases/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../bin/core.dll": "core.dll"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
