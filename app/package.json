{
  "name": "maoloader",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:tauri": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"../scripts/build-core.ps1; bun run dev\"",
    "build": "vite build",
    "build:tauri": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"../scripts/build-core.ps1 -Release; bun run build\"",
    "build:core": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/build-core.ps1",
    "build:core:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/build-core.ps1 -Release",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:runtime": "bun test src-tauri/runtime/preload.test.js",
    "test:inject": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/smoke-inject-core.ps1",
    "test:league:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/smoke-league-client.ps1",
    "tauri": "tauri"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@lucide/svelte": "^1.17.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.9.1",
    "clsx": "^2.1.1",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
